# Cloudflare 部署按钮 / Wrangler 本地开发模板。
# 这里只放 Worker Secret；普通变量 SUPABASE_URL 由 wrangler.toml 的 [vars] 声明。
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
JWT_SECRET=replace-with-a-long-random-local-dev-secret-at-least-32-bytes
# Optional: public demo mode. Restores the saved demo snapshot every 30 minutes.
# DEMO_RESET_ENABLED=true
